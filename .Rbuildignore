# R package files
^cran-comments\.md$
^.*\.Rproj$
^\.Rproj\.user$
^man-roxygen$
^LICENSE\.md$
^index.Rmd$
^pkgdown$
^pkgdown/_pkgdown\.yaml$
^docs$
^CRAN-RELEASE$
^renv$
^renv\.lock$

# npm files
^srcts$
^node_modules$
^package\.json$
^package-lock\.json$
^tsconfig\.json$
^eslint\.config\.mjs$
^\.browserslistrc$
^\.stylelintrc$

# config and meta files
^\.git$
^\.github$
^\.travis\.yml$
^codecov\.yml$
^\.vscode$
^\.claude$
^plan-.*\.md$
^AGENTS.md$
^BSLIB\.md$
^CONTRIBUTING\.md$
^bin$
